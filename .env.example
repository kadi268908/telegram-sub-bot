# Core (required)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# If your Mongo password contains special characters (e.g. @, :, /), URL-encode them.
# Example: p@ssword -> p%40ssword
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.yifwyrd.mongodb.net/?appName=Cluster0

LOG_CHANNEL_ID=-100XXXXXXXXXX

# Super admin (required: one of these)
SUPER_ADMIN_IDS=123456789,987654321
# SUPER_ADMIN_ID=123456789

# Premium groups (set all 3 for category-based plans)
MOVIE_PREMIUM_GROUP_ID=-1001111111111
DESI_PREMIUM_GROUP_ID=-1002222222222
NON_DESI_PREMIUM_GROUP_ID=-1003333333333

# Optional fallback general group
# PREMIUM_GROUP_ID=-1004444444444

# Support (strongly recommended)
SUPPORT_GROUP_ID=-1005555555555
SUPPORT_CONTACT=@YourSupportBot

# Runtime
NODE_ENV=production
PORT=3000

# Optional DNS fallback for Mongo SRV lookup
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional Mongo initial-connect retry tuning (helps with transient DNS issues)
MONGO_CONNECT_RETRY_BASE_MS=5000
MONGO_CONNECT_RETRY_MAX_MS=60000
MONGO_CONNECT_RETRY_JITTER_MS=1500

# Subscription/referral defaults
INVITE_LINK_TTL_MINUTES=10
REFERRAL_REWARD_DISCOUNT_PERCENT=10
REJOINING_PENALTY=20

# Seller program
SELLER_COMMISSION_PERCENT=15
SELLER_MIN_WITHDRAW_REFERRALS=10
SELLER_MIN_WITHDRAW_BALANCE=200
SELLER_WITHDRAW_MIN_PROCESS_HOURS=24
SELLER_PAYOUT_HISTORY_LIMIT=10

# Phase 3: anti-fraud + pending-request reminders
PAYMENT_PROOF_SPAM_WINDOW_MINUTES=10
PAYMENT_PROOF_MAX_ATTEMPTS=5
PAYMENT_PROOF_COOLDOWN_MINUTES=30
PENDING_REQUEST_REMINDER_AFTER_HOURS=2
PENDING_REQUEST_REMINDER_REPEAT_HOURS=12

# Optional cron customizations
CRON_TIMEZONE=Asia/Kolkata
# REMINDER_CRON_SCHEDULES=0 8 * * *,0 20 * * *
PROTECT_BOT_MESSAGES=true