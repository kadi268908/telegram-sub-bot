# Telegram Bot Token from @BotFather
BOT_TOKEN=Bot your_bot_token_here

# MongoDB Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.yifwyrd.mongodb.net/?appName=Cluster0


# Telegram Premium Group ID (negative number, e.g. -1001234567890)
PREMIUM_GROUP_ID=<your_premium_group_id>

# Telegram Log Channel ID (negative number, e.g. -1001234567891)
LOG_CHANNEL_ID=<your_log_channel_id>

# Super Admin Telegram User ID (numeric)
SUPER_ADMIN_IDS=<your_telegram_user_id1>,<your_telegram_user_id2>

# Node environment
NODE_ENV=production

# Express health check port (optional)
PORT=3000

# Optional: DNS servers for MongoDB SRV lookup fallback (comma-separated)
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Rejoining penalty (INR) shown to users who left the group with an active subscription
REJOINING_PENALTY=20

# Grace period days after expiry before user is removed from group
GRACE_PERIOD_DAYS=3

# Referral bonus days awarded when referred user subscribes
BONUS_REFERRAL_DAYS=3

# Invite link TTL in minutes for premium join links
INVITE_LINK_TTL_MINUTES=1

# Support contact shown when daily limit is reached or chat is closed
SUPPORT_CONTACT=@ImaxSupport1Bot

# Support Forum Group ID (Telegram group with Topics/Forum mode enabled)
# Add bot as admin with full permissions in this group
SUPPORT_GROUP_ID=<your_support_group_id>

# npm run import:legacy-csv -- --file data/legacy-users.csv --plan 30 --expiry 31/03/2026 --skipGroupCheck true


